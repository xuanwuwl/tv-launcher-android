<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1a1a2e">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TV Launcher"
        android:textSize="28sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#00ff88"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:padding="15dp"
        android:background="#16213e"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Refresh Status"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Commands:\n\n"
        android:textColor="#aaaaaa"
        android:textSize="14sp"
        android:layout_marginTop="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• CMD_PING - Heartbeat\n• CMD_GET_STATUS - Device info\n• CMD_CHANGE_APP:pkg - Change auto-start\n• CMD_GET_APPS - List apps\n• CMD_LAUNCH:pkg - Launch app\n• CMD_REBOOT - Restart device"
        android:textColor="#666666"
        android:textSize="12sp"
        android:fontFamily="monospace"/>

</LinearLayout>
